# smartctl-proxy.conf.example
#
# Configuration for the smartctl proxy wrapper (smartctl-vm-wrapper.sh).
#
# Install INSIDE the Protect VM as /etc/default/smartctl-proxy:
#
#   install -m 0600 smartctl-proxy.conf.example /etc/default/smartctl-proxy
#
# The wrapper sources this file on every invocation. While PROXY_HOST is
# empty the wrapper falls back to the local real smartctl, so the proxy
# stays inert until you finish filling this in.
#
# This is sourced as a shell file — keep it to plain VAR=value lines.

# LAN IP (or hostname) of the Mac running the QEMU host. REQUIRED.
PROXY_HOST=

# macOS user the VM SSHes in as — the user that runs start-protect-vm.sh
# and whose authorized_keys carries the forced-command key.
PROXY_USER=YOUR_MAC_USERNAME

# SSH private key the wrapper authenticates with. Generated in the VM
# during install (ssh-keygen ... -f /etc/protect-smartctl-proxy/id_ed25519).
PROXY_KEY=/etc/protect-smartctl-proxy/id_ed25519
